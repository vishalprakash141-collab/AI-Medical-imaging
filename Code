import torch
import torchvision.models as models
import torch.nn as nn

# 1. Define the exact same model architecture you trained
print("Loading model architecture...")
device = torch.device("cpu") # It's usually safer to export on CPU
model = models.resnet50()
num_ftrs = model.fc.in_features
model.fc = nn.Linear(num_ftrs, 2) # 2 classes: NORMAL and PNEUMONIA

# 2. Load your trained weights
# Make sure the path points to your saved .pth file
weights_path = 'chest_xray_resnet50.pth'
print(f"Loading weights from {weights_path}...")
model.load_state_dict(torch.load(weights_path, map_location=device))
model.eval() # MUST be in eval mode for export!

# 3. Create a "dummy" input tensor
# This tells ONNX what shape of data to expect (Batch Size, Channels, Height, Width)
dummy_input = torch.randn(1, 3, 224, 224, requires_grad=True).to(device)

# 4. Export the model
onnx_filename = "radtriage_resnet50.onnx"
print(f"Exporting model to {onnx_filename}...")

# UPDATED: Removed opset_version to let PyTorch use its default/compatible version
# This prevents the version_converter assertion errors.
torch.onnx.export(
    model,                       # model being run
    dummy_input,                 # model input (or a tuple for multiple inputs)
    onnx_filename,               # where to save the model
    export_params=True,          # store the trained parameter weights inside the model file
    do_constant_folding=True,    # whether to execute constant folding for optimization
    input_names = ['input'],     # the model's input names
    output_names = ['output'],   # the model's output names
    dynamic_axes={'input' : {0 : 'batch_size'},    # variable length axes
                  'output' : {0 : 'batch_size'}}
)

print("✅ ONNX export complete! You can now download radtriage_resnet50.onnx from the sidebar.")










